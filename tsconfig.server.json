{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist/server",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["server/**/*", "prisma/seed.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
